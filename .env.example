# ── DATABASE ──────────────────────────────────
DATABASE_URL="postgresql://user:password@ep-example.neon.tech/neondb?sslmode=require"

# ── NEXTAUTH ──────────────────────────────────
AUTH_SECRET="generate-dengan-openssl-rand-base64-32"
# Wajib diubah ke domain Vercel production: https://namaproject.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ── CLOUDINARY ────────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
# Storage limit in bytes (default 25GB for free plan). Set sesuai plan Cloudinary kamu.
CLOUDINARY_STORAGE_LIMIT_BYTES="26843545600"

# ── UPSTASH REDIS ─────────────────────────────
UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token"

# ── SMTP (Email) ───────────────────────────────
# Gmail: gunakan App Password (butuh 2FA enabled)
# Buat di: https://myaccount.google.com/apppasswords
# Provider lain: isi SMTP_HOST, SMTP_PORT sesuai provider
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM_EMAIL="your-email@gmail.com"
# Nama pengirim yang tampil di inbox Gmail (default: "ND Journey")
SMTP_FROM_NAME="ND Journey"

# ── PUSHER (Real-time Sync) ────────────────────
PUSHER_APP_ID="your_pusher_app_id"
PUSHER_SECRET="your_pusher_secret"
NEXT_PUBLIC_PUSHER_APP_KEY="your_pusher_app_key"
NEXT_PUBLIC_PUSHER_CLUSTER="your_pusher_cluster"

# ── CRON ──────────────────────────────────────
CRON_SECRET="generate-strong-random-secret-untuk-cron-job"

# ── APP CONFIG ────────────────────────────────
INVITE_TOKEN="rahasia-invite-token-untuk-registrasi-pasangan"
