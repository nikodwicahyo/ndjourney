generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String        @id @default(cuid())
  name            String?
  email           String        @unique
  emailVerified   DateTime?
  image           String?
  password        String?
  role            Role          @default(PARTNER)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  accounts        Account[]
  coupleMembers   CoupleMember?
  locationShare   LocationShare?
  userLocation      UserLocation?
  userLocationHistory UserLocationHistory[]
  dailyNotes        DailyNote[]
  gameScores      GameScore[]
  gameArcadeScores GameArcadeScore[]
  letters         Letter[]      @relation("LetterAuthor")
  receivedLetters Letter[]      @relation("LetterRecipient")
  milestones      Milestone[]
  photos          Photo[]
  sessions        Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Couple {
  id         String         @id @default(cuid())
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  members    CoupleMember[]
  dailyNotes DailyNote[]
  letters    Letter[]
  milestones Milestone[]
  photos     Photo[]
  wishes     WishItem[]
  locationShares     LocationShare[]
  userLocations      UserLocation[]
  userLocationHistory UserLocationHistory[]
}

model CoupleMember {
  id       String @id @default(cuid())
  coupleId String
  userId   String @unique
  couple   Couple @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([coupleId, userId])
}

model CoupleConfig {
  id                 String    @id @default(cuid())
  name1              String
  name2              String
  anniversaryDate    DateTime
  tagline            String?
  heroPhotoUrl       String?
  spotifyPlaylistUrl String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  birthDate1         DateTime?
  birthDate2         DateTime?
  backgroundMusicUrl String?
  targetMilestones    Int?
  targetNotes         Int?
  targetLetters       Int?
  targetPhotos        Int?
  targetSetAt         DateTime?
  targetMetAt         DateTime?
}

model Photo {
  id              String           @id @default(cuid())
  url             String
  publicId        String
  thumbnailUrl    String?
  caption         String?
  takenAt         DateTime?
  width           Int?
  height          Int?
  fileSize        Int?
  isVideo         Boolean          @default(false)
  isFavorite      Boolean          @default(false)
  albumId         String?
  uploadedById    String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  coupleId        String?
  isMilestoneOnly Boolean          @default(false)
  isPublic        Boolean          @default(true)
  milestones      MilestonePhoto[]
  album           Album?           @relation(fields: [albumId], references: [id])
  couple          Couple?          @relation(fields: [coupleId], references: [id])
  uploadedBy      User             @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([albumId])
  @@index([uploadedById])
  @@index([createdAt])
  @@index([takenAt])
  @@index([isFavorite])
  @@index([isPublic])
  @@index([albumId, createdAt])
  @@index([uploadedById, createdAt])
  @@index([isFavorite, createdAt])
}

model Album {
  id            String   @id @default(cuid())
  name          String
  description   String?
  coverPhotoUrl String?
  isPublic      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  photos        Photo[]

  @@index([createdAt])
}

model Milestone {
  id          String           @id @default(cuid())
  title       String
  description String?
  date        DateTime
  icon        String?
  color       String?
  location    String?
  isPublic    Boolean          @default(true)
  createdById String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  coupleId    String?
  couple      Couple?          @relation(fields: [coupleId], references: [id])
  createdBy   User             @relation(fields: [createdById], references: [id], onDelete: Cascade)
  photos      MilestonePhoto[]

  @@index([createdById])
  @@index([date])
  @@index([createdAt])
  @@index([date, createdById])
  @@index([isPublic, date])
}

model MilestonePhoto {
  milestoneId String
  photoId     String
  milestone   Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  photo       Photo     @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@id([milestoneId, photoId])
}

model Letter {
  id                 String     @id @default(cuid())
  title              String
  content            String
  authorId           String
  recipientId        String
  isTimeCapsule      Boolean    @default(false)
  unlockAt           DateTime?
  isOpened           Boolean    @default(false)
  openedAt           DateTime?
  mood               LetterMood @default(LOVE)
  isPublic           Boolean    @default(false)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  coupleId           String?
  notificationSentAt DateTime?
  author             User       @relation("LetterAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  couple             Couple?    @relation(fields: [coupleId], references: [id])
  recipient          User       @relation("LetterRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([recipientId])
  @@index([createdAt])
  @@index([recipientId, isOpened, createdAt])
  @@index([authorId, createdAt])
  @@index([isTimeCapsule, isOpened, unlockAt])
}

model DailyNote {
  id        String   @id @default(cuid())
  content   String
  authorId  String
  date      DateTime @default(now()) @db.Date
  createdAt DateTime @default(now())
  coupleId  String?
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  couple    Couple?  @relation(fields: [coupleId], references: [id])

  @@index([authorId])
  @@index([date])
  @@index([date, authorId])
}

model GameQuestion {
  id        String      @id @default(cuid())
  type      GameType
  question  String
  optionA   String?
  optionB   String?
  answer    String?
  category  String?
  createdAt DateTime    @default(now())
  isArchived Boolean   @default(false)
  scores    GameScore[]

  @@index([type])
  @@index([isArchived])
}

model GameScore {
  id         String       @id @default(cuid())
  userId     String?
  questionId String
  isCorrect  Boolean
  playedAt   DateTime     @default(now())
  playerName String?
  question   GameQuestion @relation(fields: [questionId], references: [id])
  user       User?        @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([questionId])
  @@index([userId, isCorrect])
  @@index([playerName])
}

model GameArcadeScore {
  id         String   @id @default(cuid())
  gameType   GameType
  userId     String?
  playerName String?
  score      Int
  metadata   Json?
  playedAt   DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([gameType])
  @@index([gameType, score])
}

model LocationShare {
  id        String   @id @default(cuid())
  userId    String   @unique
  coupleId  String
  isSharing Boolean  @default(false)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  couple    Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  @@index([coupleId])
}

model UserLocation {
  id         String    @id @default(cuid())
  userId     String    @unique
  coupleId   String
  latitude   Float
  longitude  Float
  accuracy   Float?
  heading    Float?
  speed      Float?
  altitude   Float?
  deviceType String
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  couple     Couple    @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  @@index([coupleId])
}

model UserLocationHistory {
  id        String   @id @default(cuid())
  userId    String
  coupleId  String
  latitude  Float
  longitude Float
  accuracy  Float?
  heading   Float?
  speed     Float?
  altitude  Float?
  deviceType String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  couple    Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([coupleId])
}

model WishItem {
  id          String    @id @default(cuid())
  title       String
  description String?
  imageUrl    String?
  link        String?
  category    String?
  isDone      Boolean   @default(false)
  doneAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  coupleId    String?
  couple      Couple?   @relation(fields: [coupleId], references: [id])

  @@index([category])
  @@index([isDone])
  @@index([isDone, createdAt])
  @@index([category, isDone])
}

enum Role {
  PARTNER
  ADMIN
}

enum LetterMood {
  LOVE
  GRATEFUL
  MISSING
  HAPPY
  APOLOGY
  SURPRISE
}

enum GameType {
  WOULD_YOU_RATHER
  TRIVIA
  SPIN_THE_WHEEL
  TRUTH_OR_DARE
  SLIDING_PUZZLE
  MEMORY_BLOCK_BLAST
}
